# Database Configuration — plain text, no URL encoding needed
# Special characters in DB_PASSWORD (!, ^, %, etc.) can be written as-is.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=game
DB_PASSWORD=uu5!^%jg
DB_NAME=d_taiwan

# AES-256-GCM Encryption Key (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
AES_KEY=a1b2c3d4e5f6789012345678901234567890abcdef0123456789abcdef012345

# RSA Private Key Path
RSA_PRIVATE_KEY_PATH=/data/privatekey.pem

# Server Bind Address
BIND_ADDRESS=0.0.0.0:5505

# Initial balances granted to newly registered accounts
INITIAL_CERA=1000
INITIAL_CERA_POINT=0

# TLS (optional). Requires both TLS_CERT_PATH and TLS_KEY_PATH.
# When TLS is configured, HTTP and HTTPS are served on separate ports unless TLS_ONLY=true.
# TLS_CERT_PATH=/data/server.crt   # PEM certificate, may include CA chain
# TLS_KEY_PATH=/data/server.key    # PEM private key
# TLS_BIND_ADDRESS=0.0.0.0:5504    # HTTPS listener address
# TLS_ONLY=false                   # Disable HTTP when TLS is active

# Game Server IP (optional)
# The IP of the DNF game server. May differ from the address of this gate server.
GAME_SERVER_IP=192.168.200.131

# Log Level
RUST_LOG=info,dnf_gate_server=debug
